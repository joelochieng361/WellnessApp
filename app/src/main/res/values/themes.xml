<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WellnessApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <style name="Theme.WellnessApp" parent="Base.Theme.WellnessApp" />

    <!-- Health Theme -->
    <style name="Theme.WellnessApp.Health" parent="Theme.WellnessApp">
        <item name="android:windowBackground">@color/health_background</item>
        <item name="colorPrimary">@color/health_primary</item>
    </style>

    <!-- Exercise Theme -->
    <style name="Theme.WellnessApp.Exercise" parent="Theme.WellnessApp">
        <item name="android:windowBackground">@color/exercise_background</item>
        <item name="colorPrimary">@color/exercise_primary</item>
    </style>

    <!-- Nutrition Theme -->
    <style name="Theme.WellnessApp.Nutrition" parent="Theme.WellnessApp">
        <item name="android:windowBackground">@color/nutrition_background</item>
        <item name="colorPrimary">@color/nutrition_primary</item>
    </style>

    <!-- Meditation Theme -->
    <style name="Theme.WellnessApp.Meditation" parent="Theme.WellnessApp">
        <item name="android:windowBackground">@color/meditation_background</item>
        <item name="colorPrimary">@color/meditation_primary</item>
    </style>

    <!-- Motivation Theme -->
    <style name="Theme.WellnessApp.Motivation" parent="Theme.WellnessApp">
        <item name="android:windowBackground">@color/motivation_background</item>
        <item name="colorPrimary">@color/motivation_primary</item>
    </style>

