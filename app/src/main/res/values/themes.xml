    <!-- Hydration Theme -->
    <style name="Theme.WellnessApp.Hydration" parent="Theme.WellnessApp">
        <item name="android:windowBackground">@color/hydration_background</item>
        <item name="colorPrimary">@color/hydration_primary</item>
    </style>

</resources>